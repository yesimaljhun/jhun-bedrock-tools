<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<link rel="icon" type="image/jpeg" href="data:image/jpeg;base64,">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="theme-color" content="#0d1117">
<title>Jun's Pack Editor</title>
<link rel="manifest" id="manifest-link">
<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<style>
:root {
--bg:#0d1117; --surface:#161b22; --surface2:#1c2330;
--border:#30363d; --border2:#3d4450;
--green:#3fb950; --green-dim:#238636;
--blue:#58a6ff; --gold:#d29922; --red:#f85149; --purple:#bc8cff;
--text:#e6edf3; --muted:#8b949e; --dim:#484f58;
--pixel:'Press Start 2P',monospace; --mono:'JetBrains Mono',monospace;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{width:100%;height:100%;overflow:hidden}
body{font-family:var(--mono);background:transparent;color:var(--text);display:flex;flex-direction:column}

/* ── HEADER ── */
#header{height:50px;flex-shrink:0;background:var(--surface);border-bottom:2px solid var(--border);display:flex;align-items:center;gap:10px;padding:0 14px}
#logo{font-family:var(--pixel);font-size:8px;color:var(--green);text-shadow:0 0 16px rgba(63,185,80,.4);white-space:nowrap}
#logo span{color:var(--blue)}
#pack-tabs{display:flex;align-items:center;gap:4px;overflow-x:auto;max-width:440px;flex-shrink:1}
#pack-tabs::-webkit-scrollbar{height:3px}
#pack-tabs::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}
.pack-tab{font-size:11.5px;color:var(--muted);background:var(--surface2);border:1px solid var(--border);padding:3px 8px 3px 10px;border-radius:4px;max-width:170px;overflow:hidden;white-space:nowrap;cursor:pointer;display:flex;align-items:center;gap:5px;flex-shrink:0;transition:all .15s}
.pack-tab:hover{border-color:var(--green);color:var(--text)}
.pack-tab.active{color:var(--green);border-color:var(--green);background:var(--surface)}
.pack-tab .tab-name{overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:118px}
.pack-tab .tab-close{flex-shrink:0;opacity:.4;font-size:11px;line-height:1;padding:1px 3px;border-radius:2px}
.pack-tab .tab-close:hover{opacity:1;background:rgba(255,80,80,.25)}
#btn-add-tab{font-size:15px;line-height:1;padding:1px 7px 2px;background:transparent;border:1px solid var(--border);border-radius:4px;color:var(--muted);cursor:pointer;flex-shrink:0;font-weight:400}
#btn-add-tab:hover{border-color:var(--green);color:var(--green)}
.spacer{flex:1}
button{font-family:var(--mono);font-size:12.6px;font-weight:600;border:none;border-radius:4px;padding:6px 12px;cursor:pointer;white-space:nowrap;transition:all .15s}
.btn-p{background:var(--green-dim);color:#fff;border:1px solid var(--green)}
.btn-p:hover{background:var(--green)}
.btn-p:disabled{opacity:.35;cursor:default}
.btn-s{background:transparent;color:var(--muted);border:1px solid var(--border)}
.btn-s:hover{color:var(--text);border-color:var(--border2);background:var(--surface2)}
.btn-d{background:transparent;color:var(--red);border:1px solid transparent;font-size:11.5px;padding:5px 9px}
.btn-d:hover{border-color:var(--red);background:rgba(248,81,73,.1)}
.ibtn{background:transparent;color:var(--muted);border:1px solid var(--border);border-radius:4px;padding:5px 8px;cursor:pointer;font-size:14.9px;line-height:1;transition:all .15s}
.ibtn:hover{color:var(--text);border-color:var(--border2);background:var(--surface2)}
.ibtn.on{color:var(--green);border-color:var(--green);background:rgba(63,185,80,.1)}

/* ── BODY ── */
#body{display:flex;flex:1;overflow:hidden;min-height:0}

/* ── SIDEBAR ── */
#sidebar{width:260px;flex-shrink:0;background:var(--surface);border-right:2px solid var(--border);display:flex;flex-direction:column;overflow:hidden}
#sidebar-top{border-bottom:1px solid var(--border);padding:8px}
#search{padding:6px 10px;background:var(--bg);border:1px solid var(--border);border-radius:4px;color:var(--text);font-family:var(--mono);font-size:12.6px;outline:none;display:block;width:100%}
#search:focus{border-color:var(--blue)}
#search::placeholder{color:var(--dim)}
#file-tree{flex:1;overflow-y:auto;padding:4px 0;font-size:12.6px}
#file-tree::-webkit-scrollbar{width:5px}
#file-tree::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}

/* tree nodes */
.folder-row{display:flex;align-items:center;gap:5px;padding:3px 6px;cursor:pointer;user-select:none;color:var(--muted);transition:color .1s}
.folder-row:hover{color:var(--text);background:rgba(255,255,255,.03)}
.folder-icon{font-size:13.8px;flex-shrink:0;transition:transform .15s}
.folder-row.open .folder-icon{transform:rotate(90deg)}
.folder-label{overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1;font-size:12.6px}
.folder-children{padding-left:14px}
.folder-children.closed{display:none}

.file-row{display:flex;align-items:center;gap:6px;padding:3px 6px;cursor:pointer;color:var(--muted);transition:all .1s;border-left:2px solid transparent;position:relative}
.file-row:hover{color:var(--text);background:rgba(255,255,255,.03)}
.file-row.active{color:var(--green);background:rgba(63,185,80,.07);border-left-color:var(--green)}
.file-row.dirty::after{content:'●';position:absolute;right:6px;color:var(--gold);font-size:8px}
.file-icon{font-size:14.9px;flex-shrink:0;width:16px;text-align:center}
.file-name{overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1}
.tex-thumb{width:20px;height:20px;flex-shrink:0;image-rendering:pixelated;border-radius:2px;background:repeating-conic-gradient(#2a2a2a 0% 25%,#1a1a1a 0% 50%) 0 0/8px 8px}

/* play button on audio rows */
.play-snd-btn{
flex-shrink:0;width:20px;height:20px;border-radius:50%;
background:transparent;border:1px solid var(--border);
color:var(--muted);font-size:10.3px;cursor:pointer;
display:flex;align-items:center;justify-content:center;
transition:all .15s;line-height:1;padding:0;
margin-left:2px;
}
.play-snd-btn:hover{background:var(--green);border-color:var(--green);color:#000;}
.play-snd-btn.playing{background:var(--green);border-color:var(--green);color:#000;animation:snd-pulse 1s ease-in-out infinite;}
@keyframes snd-pulse{0%,100%{box-shadow:0 0 0 0 rgba(63,185,80,.5)}50%{box-shadow:0 0 0 5px rgba(63,185,80,0)}}

/* delete button on all file rows — hidden until row is hovered */
.del-file-btn{
flex-shrink:0;width:18px;height:18px;border-radius:3px;
background:transparent;border:1px solid transparent;
color:transparent;font-size:11.5px;cursor:pointer;
display:flex;align-items:center;justify-content:center;
transition:all .12s;line-height:1;padding:0;margin-left:2px;
}
.file-row:hover .del-file-btn{color:var(--dim);border-color:var(--border);}
.del-file-btn:hover{background:rgba(248,81,73,.15)!important;border-color:var(--red)!important;color:var(--red)!important;}

/* ── EDITOR AREA ── */
#editor{flex:1;display:flex;flex-direction:column;overflow:hidden;min-width:0}

/* ── TOOLBAR (image) ── */
#toolbar-img{height:44px;flex-shrink:0;background:var(--surface);border-bottom:1px solid var(--border);display:flex;align-items:center;gap:6px;padding:0 10px;overflow-x:auto;display:none}
.tgrp{display:flex;gap:4px;padding-right:8px;border-right:1px solid var(--border);align-items:center;flex-shrink:0}
.tgrp:last-child{border-right:none}
#zoom-lbl{font-size:12.6px;color:var(--muted);min-width:36px;text-align:center}

/* ── TOOLBAR (text) ── */
#toolbar-txt{height:44px;flex-shrink:0;background:var(--surface);border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px;padding:0 12px;display:none}
#toolbar-txt .file-title{font-size:13.8px;color:var(--text);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1}
#toolbar-txt .file-type-badge{font-size:10.3px;padding:2px 7px;border-radius:10px;border:1px solid var(--border);color:var(--muted);background:var(--surface2);flex-shrink:0}

/* ── CANVAS AREA ── */
#canvas-area{flex:1;position:relative;overflow:auto;background-color:transparent;background-image:linear-gradient(45deg,rgba(26,26,26,0.6) 25%,transparent 25%),linear-gradient(-45deg,rgba(26,26,26,0.6) 25%,transparent 25%),linear-gradient(45deg,transparent 75%,rgba(26,26,26,0.6) 75%),linear-gradient(-45deg,transparent 75%,rgba(26,26,26,0.6) 75%);background-size:16px 16px;background-position:0 0,0 8px,8px -8px,-8px 0;display:none}
#canvas-area.tool-cursor{cursor:grab}
#canvas-area.tool-cursor.panning{cursor:grabbing}
#canvas-area::-webkit-scrollbar-thumb{background:var(--border);border-radius:4px}
#canvas-center{min-width:100%;min-height:100%;width:max-content;display:flex;align-items:center;justify-content:center;padding:30px;box-sizing:border-box}
#canvas-wrap{position:relative;flex-shrink:0;line-height:0}
#main-canvas{display:block;image-rendering:pixelated;image-rendering:crisp-edges;cursor:crosshair}
#grid-canvas{position:absolute;top:0;left:0;pointer-events:none;display:none}
#cursor-info{position:absolute;bottom:10px;left:10px;z-index:30;background:rgba(13,17,23,.9);border:1px solid var(--border);border-radius:4px;padding:3px 8px;font-size:11.5px;color:var(--muted);pointer-events:none;display:none}

/* ── TEXT EDITOR ── */
#text-area{flex:1;display:none;flex-direction:column;overflow:hidden}
#text-editor{flex:1;background:rgba(13,17,23,0.75);color:var(--text);font-family:var(--mono);font-size:13.8px;line-height:1.6;border:none;outline:none;resize:none;padding:16px;tab-size:2;white-space:pre;overflow:auto}
#text-editor::-webkit-scrollbar{width:8px;height:8px}
#text-editor::-webkit-scrollbar-thumb{background:var(--border);border-radius:4px}
#text-status{height:26px;flex-shrink:0;background:var(--surface);border-top:1px solid var(--border);display:flex;align-items:center;gap:12px;padding:0 12px;font-size:11.5px;color:var(--dim)}
#text-status span{color:var(--muted)}

/* ── AUDIO EDITOR ── */
#audio-area {
flex:1; display:none; flex-direction:column;
background: transparent; overflow-y:auto; overflow-x:hidden;
}
#audio-shell {
width:100%; max-width:860px; margin:0 auto;
padding:28px 28px 36px; display:flex; flex-direction:column; gap:20px;
}

/* header */
.aud-header { display:flex; align-items:center; gap:14px; }
.aud-icon { font-size:32.2px; flex-shrink:0; }
.aud-header-text { flex:1; min-width:0; }
.aud-filename { font-family:var(--pixel); font-size:10.3px; color:var(--green); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; margin-bottom:5px; }
.aud-meta { font-size:11.5px; color:var(--dim); }

/* waveform */
.aud-waveform-section { display:flex; flex-direction:column; gap:6px; }
#waveform-wrap {
position:relative; width:100%; height:120px;
background:var(--surface); border:1px solid var(--border);
border-radius:8px; overflow:hidden; cursor:pointer;
}
#waveform-wrap:hover { border-color:var(--border2); }
#waveform-canvas { display:block; width:100%; height:100%; }
#waveform-progress {
position:absolute; top:0; left:0; width:0%; height:100%;
background:rgba(63,185,80,.1); pointer-events:none;
border-right:2px solid var(--green);
}
.aud-time { display:flex; justify-content:space-between; font-size:11.5px; color:var(--dim); padding:0 2px; }

/* big transport row */
.aud-transport {
display:flex; align-items:center; justify-content:center; gap:12px;
background:var(--surface); border:1px solid var(--border);
border-radius:8px; padding:14px;
}
.aud-tbtn {
width:38px; height:38px; border-radius:50%;
border:1px solid var(--border); background:var(--surface2);
color:var(--muted); font-size:17.2px; cursor:pointer;
transition:all .15s; display:flex; align-items:center; justify-content:center;
flex-shrink:0;
}
.aud-tbtn:hover { color:var(--text); border-color:var(--border2); background:#252d3a; }
#aud-play {
width:56px; height:56px; font-size:25.3px;
border-color:var(--green); color:var(--green); background:rgba(63,185,80,.08);
}
#aud-play:hover { background:var(--green); color:#000; box-shadow:0 0 20px rgba(63,185,80,.35); }
#aud-play.is-playing { background:var(--green); color:#000; }
#aud-loop.on { color:var(--blue); border-color:var(--blue); background:rgba(88,166,255,.1); }

/* editor panels grid */
.aud-panels { display:grid; grid-template-columns:1fr 1fr; gap:14px; }

/* each panel card */
.aud-panel {
background:var(--surface); border:1px solid var(--border);
border-radius:8px; padding:16px; display:flex; flex-direction:column; gap:12px;
}
.aud-panel-title {
font-family:var(--pixel); font-size:6.9px; color:var(--dim);
letter-spacing:1px; text-transform:uppercase;
display:flex; justify-content:space-between; align-items:center;
}
.aud-panel-title .aud-val {
font-family:var(--mono); font-size:14.9px; font-weight:600; color:var(--text); letter-spacing:0;
}

/* visual bar (the big coloured slider track) */
.aud-bar-wrap { position:relative; height:8px; border-radius:4px; background:var(--surface2); cursor:pointer; }
.aud-bar-fill { height:100%; border-radius:4px; transition:width .05s; }
.aud-bar-wrap input[type=range] {
position:absolute; inset:0; width:100%; height:100%;
opacity:0; cursor:pointer; margin:0;
}

/* pitch specific */
.pitch-fill   { background:linear-gradient(90deg, #6366f1, #a855f7, #ec4899); }
.pitch-center { position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); width:2px; height:140%; background:rgba(255,255,255,.2); border-radius:1px; pointer-events:none; }

/* semitone row */
.semi-row { display:flex; align-items:center; gap:8px; }
.semi-step {
background:var(--surface2); border:1px solid var(--border);
border-radius:4px; color:var(--muted); font-size:11.5px;
padding:4px 10px; cursor:pointer; transition:all .1s; white-space:nowrap;
font-family:var(--mono);
}
.semi-step:hover { color:var(--text); border-color:var(--border2); }
.semi-readout { flex:1; text-align:center; font-size:12.6px; color:var(--muted); }

/* octave shortcut pills */
.oct-row { display:flex; gap:4px; flex-wrap:wrap; }
.oct-pill {
font-size:10.3px; padding:3px 8px; border-radius:10px;
border:1px solid var(--border); background:var(--surface2);
color:var(--dim); cursor:pointer; transition:all .1s; font-family:var(--mono);
}
.oct-pill:hover { color:var(--text); border-color:var(--border2); }
.oct-pill.zero { border-color:var(--green); color:var(--green); }

/* volume specific */
.vol-fill { background:linear-gradient(90deg, var(--blue), #34d399); }

/* rate specific */
.rate-fill { background:linear-gradient(90deg, var(--gold), #f97316); }

/* bottom action row */
.aud-actions { display:flex; gap:10px; }
.aud-actions button { flex:1; }

/* scrollbar for audio area */
#audio-area::-webkit-scrollbar { width:6px; }
#audio-area::-webkit-scrollbar-thumb { background:var(--border); border-radius:3px; }

/* ── WELCOME / DROP OVERLAY ── */
#ov-load,#ov-hint{position:absolute;inset:0;z-index:20;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;padding:30px;background:rgba(13,17,23,0.6)}
#ov-load.off,#ov-hint.off{display:none}
#ov-hint{background:rgba(13,17,23,.6);pointer-events:none}
#ov-hint p{background:rgba(13,17,23,.95);border:1px solid var(--border);border-radius:6px;padding:12px 20px;font-size:13.8px;color:var(--dim);text-align:center;line-height:1.7}
.drop-box{border:2px dashed var(--border);border-radius:10px;padding:36px 52px;text-align:center;cursor:pointer;transition:all .2s;background:var(--surface)}
.drop-box:hover,.drop-box.over{border-color:var(--green);box-shadow:0 0 28px rgba(63,185,80,.15)}
.drop-icon{font-size:50.6px;display:block;margin-bottom:12px;animation:bob 3s ease-in-out infinite}
@keyframes bob{0%,100%{transform:translateY(0)}50%{transform:translateY(-7px)}}
.drop-box p{font-size:13.8px;color:var(--muted);line-height:1.7}
.ov-title{font-family:var(--pixel);font-size:13.8px;color:var(--green);text-shadow:0 0 24px rgba(63,185,80,.5);animation:pulse 2s ease-in-out infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.65}}
.ov-sub{font-size:13.8px;color:var(--muted);text-align:center;max-width:380px;line-height:1.7}

/* ── MAIN CONTENT AREA ── */
#main-content{flex:1;display:flex;flex-direction:column;overflow:hidden;position:relative}

/* ── RIGHT PANEL ── */
#rpanel{width:200px;flex-shrink:0;background:var(--surface);border-left:2px solid var(--border);overflow-y:auto;display:flex;flex-direction:column}
#rpanel::-webkit-scrollbar{width:5px}
#rpanel::-webkit-scrollbar-thumb{background:var(--border)}
.sec{padding:11px 12px;border-bottom:1px solid var(--border)}
.sec-lbl{font-family:var(--pixel);font-size:6.3px;color:var(--dim);letter-spacing:1px;text-transform:uppercase;margin-bottom:9px}
.kv{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:5px;font-size:12.6px}
.kv .k{color:var(--muted)}.kv .v{color:var(--text);font-weight:600;max-width:110px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
#i-path{font-size:10.3px;color:var(--muted);word-break:break-all;line-height:1.5;margin-top:4px}
#c-swatch{width:40px;height:40px;border-radius:5px;border:2px solid var(--border);flex-shrink:0;background:#3fb950}
#c-hex{width:100%;background:var(--bg);border:1px solid var(--border);border-radius:4px;color:var(--text);font-family:var(--mono);font-size:12.6px;padding:4px 8px;outline:none;margin-top:6px;text-transform:uppercase}
#c-hex:focus{border-color:var(--blue)}
.srow{display:flex;align-items:center;gap:6px;font-size:11.5px;margin-top:5px}
.srow label{color:var(--muted);width:12px}
.srow input[type=range]{flex:1;accent-color:var(--green);height:3px}
.srow .sv{color:var(--text);width:25px;text-align:right}
input[type=color]{width:28px;height:28px;border-radius:4px;border:2px solid var(--border);cursor:pointer;padding:0;background:none}
#palette{display:grid;grid-template-columns:repeat(8,1fr);gap:3px;margin-top:6px}
.pcell{aspect-ratio:1;border-radius:2px;cursor:pointer;border:1px solid transparent;transition:transform .1s}
.pcell:hover{transform:scale(1.25);border-color:rgba(255,255,255,.2)}
.pcell.on{border-color:#fff}
#hist-list{max-height:100px;overflow-y:auto;display:flex;flex-direction:column;gap:1px}
.hitem{font-size:11.5px;color:var(--muted);padding:2px 5px;border-radius:3px;cursor:pointer;display:flex;align-items:center;gap:5px}
.hitem:hover{background:var(--surface2);color:var(--text)}
.hitem.on{color:var(--green)}
.hdot{width:5px;height:5px;border-radius:50%;background:currentColor;flex-shrink:0}

/* right panel sections that hide when no image */
.img-only{display:block}.kv.img-only{display:flex}
.img-only.hidden{display:none}

/* ── SIDEBAR ACTION BUTTONS ── */
#sidebar-actions{
display:none; flex-direction:column; gap:6px;
padding:8px; border-bottom:1px solid var(--border);
}
#sidebar-actions.visible{ display:flex; }
.sb-btn{
width:100%; padding:6px 10px; font-family:var(--mono); font-size:11.5px; font-weight:600;
border-radius:4px; cursor:pointer; text-align:left; transition:all .15s;
display:flex; align-items:center; gap:7px; border:1px solid var(--border);
background:transparent; color:var(--muted);
}
.sb-btn:hover{ color:var(--text); border-color:var(--border2); background:var(--surface2); }
.sb-btn.green{ border-color:var(--green-dim); color:var(--green); background:rgba(63,185,80,.06); }
.sb-btn.green:hover{ background:rgba(63,185,80,.14); border-color:var(--green); }

/* ── INPUT PROMPT MODAL ── */
#prompt-bg{position:fixed;inset:0;background:rgba(0,0,0,.65);display:flex;align-items:center;justify-content:center;z-index:9999;backdrop-filter:blur(3px)}
#prompt-bg.off{display:none}
#prompt-box{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:22px;width:400px;box-shadow:0 20px 60px rgba(0,0,0,.5)}
#prompt-box h3{font-family:var(--pixel);font-size:9.2px;color:var(--text);margin-bottom:10px}
#prompt-box p{font-size:12.6px;color:var(--muted);margin-bottom:12px;line-height:1.5}
#prompt-input{width:100%;background:var(--bg);border:1px solid var(--border);border-radius:4px;color:var(--text);font-family:var(--mono);font-size:13.8px;padding:8px 10px;outline:none;margin-bottom:14px}
#prompt-input:focus{border-color:var(--blue)}
#prompt-acts{display:flex;justify-content:flex-end;gap:8px}

/* ── TOASTS ── */
#toasts{position:fixed;bottom:14px;right:14px;display:flex;flex-direction:column;gap:7px;z-index:9999;pointer-events:none}
.toast{background:var(--surface2);border:1px solid var(--border);border-radius:6px;padding:9px 14px;font-size:13.8px;color:var(--text);display:flex;align-items:center;gap:8px;box-shadow:0 4px 18px rgba(0,0,0,.45);animation:tin .2s ease;max-width:290px;pointer-events:all}
.toast.s{border-left:3px solid var(--green)}.toast.e{border-left:3px solid var(--red)}.toast.i{border-left:3px solid var(--blue)}
@keyframes tin{from{transform:translateX(110%);opacity:0}to{transform:translateX(0);opacity:1}}

/* ── MODAL ── */
#modal-bg{position:fixed;inset:0;background:rgba(0,0,0,.65);display:flex;align-items:center;justify-content:center;z-index:9998;backdrop-filter:blur(3px)}
#modal-bg.off{display:none}
#modal{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:22px;width:420px}
#modal h3{font-family:var(--pixel);font-size:9.2px;color:var(--text);margin-bottom:14px}
#modal p{font-size:13.8px;color:var(--muted);line-height:1.6;margin-bottom:14px}
#modal-acts{display:flex;justify-content:flex-end;gap:8px}

/* ── MISC PANEL ── */
#misc-panel{
position:fixed;top:0;left:0;bottom:0;width:350px;
background:var(--surface);border-right:2px solid var(--border);
display:flex;flex-direction:column;z-index:8000;
transform:translateX(-100%);transition:transform .25s cubic-bezier(.4,0,.2,1);
box-shadow:8px 0 40px rgba(0,0,0,.5);
}
#misc-panel.open{transform:translateX(0)}
#misc-header{
display:flex;align-items:center;justify-content:space-between;
padding:14px 16px;border-bottom:1px solid var(--border);flex-shrink:0;
}
#misc-header h2{font-family:var(--pixel);font-size:12px;color:var(--text)}
#misc-close{
background:none;border:1px solid var(--border);border-radius:4px;
color:var(--muted);font-size:16.1px;padding:3px 8px;cursor:pointer;transition:all .15s;
}
#misc-close:hover{color:var(--text);border-color:var(--border2);background:var(--surface2)}
#misc-body{flex:1;overflow-y:auto;padding:16px;display:flex;flex-direction:column;gap:18px}
#misc-body::-webkit-scrollbar{width:5px}
#misc-body::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}

/* ── CUSTOMIZER PANEL ── */
#customizer{
position:fixed; top:0; right:0; bottom:0; width:350px;
background:var(--surface); border-left:2px solid var(--border);
display:flex; flex-direction:column; z-index:8000;
transform:translateX(100%); transition:transform .25s cubic-bezier(.4,0,.2,1);
box-shadow:-8px 0 40px rgba(0,0,0,.5);
}
#customizer.open{ transform:translateX(0); }
#cust-header{
display:flex; align-items:center; justify-content:space-between;
padding:14px 16px; border-bottom:1px solid var(--border); flex-shrink:0;
}
#cust-header h2{ font-family:var(--pixel); font-size:12px; color:var(--text); }
#cust-close{
background:none; border:1px solid var(--border); border-radius:4px;
color:var(--muted); font-size:16.1px; padding:3px 8px; cursor:pointer; transition:all .15s;
}
#cust-close:hover{ color:var(--text); border-color:var(--border2); background:var(--surface2); }
#cust-body{ flex:1; overflow-y:auto; padding:16px; display:flex; flex-direction:column; gap:18px; }
#cust-body::-webkit-scrollbar{ width:5px; }
#cust-body::-webkit-scrollbar-thumb{ background:var(--border); border-radius:3px; }
#cust-footer{
padding:12px 16px; border-top:1px solid var(--border); flex-shrink:0;
display:flex; gap:8px;
}
#cust-footer button{ flex:1; }

/* customizer sections */
.cust-section{ display:flex; flex-direction:column; gap:10px; }
.cust-section-title{
font-family:var(--pixel); font-size:6.9px; color:var(--dim);
letter-spacing:1px; text-transform:uppercase; padding-bottom:6px;
border-bottom:1px solid var(--border);
}

/* theme preset pills */
.theme-grid{ display:grid; grid-template-columns:repeat(2,1fr); gap:8px; }
.theme-card{
border:2px solid var(--border); border-radius:6px; padding:10px 10px 8px;
cursor:pointer; transition:all .15s; background:var(--surface2);
display:flex; flex-direction:column; gap:6px;
}
.theme-card:hover{ border-color:var(--border2); }
.theme-card.active{ border-color:var(--green); }
.theme-card-dots{ display:flex; gap:4px; }
.theme-dot{ width:12px; height:12px; border-radius:50%; }
.theme-card-label{ font-size:11.5px; color:var(--muted); font-family:var(--mono); }

/* color rows */
.cust-color-row{
display:flex; align-items:center; justify-content:space-between;
font-size:12.6px; color:var(--muted);
}
.cust-color-row label{ flex:1; }
.cust-color-row .cust-hex{
width:80px; background:var(--bg); border:1px solid var(--border);
border-radius:4px; color:var(--text); font-family:var(--mono); font-size:11.5px;
padding:3px 6px; outline:none; text-transform:uppercase;
}
.cust-color-row .cust-hex:focus{ border-color:var(--blue); }
.cust-color-row input[type=color]{
width:26px; height:26px; border-radius:4px; border:1px solid var(--border);
cursor:pointer; padding:1px; background:none; flex-shrink:0; margin-left:6px;
}

/* font picker */
.font-grid{ display:grid; grid-template-columns:1fr 1fr; gap:6px; }
.font-card{
border:1px solid var(--border); border-radius:5px; padding:8px 10px;
cursor:pointer; transition:all .15s; background:var(--surface2);
text-align:center; font-size:13.8px; color:var(--muted);
}
.font-card:hover{ border-color:var(--border2); color:var(--text); }
.font-card.active{ border-color:var(--green); color:var(--green); background:rgba(63,185,80,.07); }

/* accent swatch row */
.accent-row{ display:flex; gap:8px; flex-wrap:wrap; }
.accent-swatch{
width:28px; height:28px; border-radius:50%; cursor:pointer;
border:2px solid transparent; transition:all .15s; flex-shrink:0;
}
.accent-swatch:hover{ transform:scale(1.15); }
.accent-swatch.active{ border-color:#fff; transform:scale(1.1); }

/* ── BACKGROUND IMAGE ── */
#bg-base{
position:fixed;inset:0;z-index:-2;background:var(--bg);pointer-events:none;
}
#bg-layer{
position:fixed;inset:0;z-index:-1;pointer-events:none;
background-size:cover;background-position:center;background-repeat:no-repeat;
transition:opacity .4s,filter .4s;
}
#bg-layer.hidden{display:none}

.bg-drop{
border:2px dashed var(--border);border-radius:8px;padding:18px 12px;
text-align:center;cursor:pointer;transition:all .2s;background:var(--surface2);
display:flex;flex-direction:column;align-items:center;gap:6px;
}
.bg-drop:hover,.bg-drop.over{border-color:var(--green);box-shadow:0 0 18px rgba(63,185,80,.15)}
.bg-drop-icon{font-size:29.9px}
.bg-drop p{font-size:11.5px;color:var(--dim);line-height:1.5;margin:0}
#bg-preview-wrap{
position:relative;border-radius:6px;overflow:hidden;border:1px solid var(--border);
background:repeating-conic-gradient(#2a2a2a 0% 25%,#1a1a1a 0% 50%) 0 0/12px 12px;
aspect-ratio:16/7;width:100%;display:none;
}
#bg-preview-img{width:100%;height:100%;object-fit:cover;display:block}
#bg-preview-badge{
position:absolute;top:5px;right:5px;background:rgba(0,0,0,.7);border-radius:4px;
padding:2px 6px;font-size:10.3px;color:var(--muted);
}
.bg-controls{display:flex;flex-direction:column;gap:8px;display:none}
.bg-ctrl-row{display:flex;align-items:center;gap:8px;font-size:11.5px;color:var(--muted)}
.bg-ctrl-row label{width:62px;flex-shrink:0}
.bg-ctrl-row input[type=range]{flex:1;accent-color:var(--green);height:3px}
.bg-ctrl-row .bv{min-width:30px;text-align:right;color:var(--text)}
.bg-blend-row{display:flex;gap:5px;flex-wrap:wrap}
.bg-blend-btn{
padding:3px 9px;font-size:10.3px;border:1px solid var(--border);border-radius:10px;
background:var(--surface2);color:var(--dim);cursor:pointer;transition:all .1s;font-family:var(--mono);
}
.bg-blend-btn:hover{border-color:var(--border2);color:var(--text)}
.bg-blend-btn.on{border-color:var(--green);color:var(--green);background:rgba(63,185,80,.1)}
.bg-action-row{display:flex;gap:6px}
.bg-action-row button{flex:1;font-size:11.5px;padding:5px 8px}
#btn-bg-theme{background:rgba(63,185,80,.1);border:1px solid var(--green-dim);color:var(--green)}
#btn-bg-theme:hover{background:rgba(63,185,80,.22);border-color:var(--green)}
#btn-bg-remove{background:rgba(248,81,73,.08);border:1px solid transparent;color:var(--red)}
#btn-bg-remove:hover{border-color:var(--red);background:rgba(248,81,73,.18)}
.bg-theme-preview{
display:flex;gap:5px;margin-top:4px;display:none;
}
.bg-theme-swatch{
flex:1;height:18px;border-radius:4px;border:1px solid rgba(255,255,255,.08);
position:relative;
}
.bg-theme-swatch::after{
content:attr(title);position:absolute;bottom:-18px;left:50%;transform:translateX(-50%);
font-size:8px;color:var(--dim);white-space:nowrap;font-family:var(--mono);
}

/* ── SKYBOX PACK INFO MODAL ── */
#sbc-info-modal-bg{position:fixed;inset:0;background:rgba(0,0,0,.7);display:flex;align-items:center;justify-content:center;z-index:10000;backdrop-filter:blur(4px)}
#sbc-info-modal-bg.off{display:none}
#sbc-info-modal{width:400px;max-width:95vw;background:var(--surface);border:1px solid var(--border);border-radius:10px;overflow:hidden;box-shadow:0 24px 60px rgba(0,0,0,.6)}
#sbc-info-modal-header{display:flex;align-items:center;justify-content:space-between;padding:13px 16px;background:var(--surface2);border-bottom:1px solid var(--border)}
#sbc-info-modal-close{background:none;border:1px solid var(--border);border-radius:4px;color:var(--muted);font-size:14.9px;padding:2px 7px;cursor:pointer;transition:all .12s;font-family:var(--mono)}
#sbc-info-modal-close:hover{color:var(--red);border-color:var(--red)}
#sbc-info-modal-body{padding:20px;display:flex;flex-direction:column;gap:14px}
#sbc-info-modal-footer{padding:12px 16px;background:var(--surface2);border-top:1px solid var(--border);display:flex;gap:8px;justify-content:flex-end}
#sbc-info-modal-footer button{font-size:12.6px;padding:6px 14px}
.sbc-field{display:flex;flex-direction:column;gap:5px}
.sbc-field-label{font-size:12.6px;color:var(--muted);font-weight:600}
.sbc-field-input{background:var(--bg);border:1px solid var(--border);border-radius:4px;color:var(--text);font-family:var(--mono);font-size:13.8px;padding:7px 10px;outline:none;width:100%}
.sbc-field-input:focus{border-color:var(--blue)}

/* ── TEXTURE CREATION MODALS ── */

/* Option picker (Blank vs Template) */
#tex-option-bg{position:fixed;inset:0;background:rgba(0,0,0,.7);display:flex;align-items:center;justify-content:center;z-index:10000;backdrop-filter:blur(4px)}
#tex-option-bg.off{display:none}
#tex-option-box{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:24px;width:400px;max-width:calc(100vw - 40px);box-sizing:border-box;box-shadow:0 24px 60px rgba(0,0,0,.6)}
#tex-option-box h3{font-family:var(--pixel);font-size:9.2px;color:var(--text);margin-bottom:6px}
#tex-option-box p{font-size:12.6px;color:var(--muted);margin-bottom:18px;line-height:1.6;word-break:break-all;overflow-wrap:anywhere;max-width:100%;overflow:hidden}
.tex-option-cards{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px}
.tex-option-card{
border:2px solid var(--border);border-radius:8px;padding:16px 12px;
cursor:pointer;transition:all .15s;background:var(--surface2);
display:flex;flex-direction:column;align-items:center;gap:8px;
text-align:center;
}
.tex-option-card:hover{border-color:var(--green);background:rgba(63,185,80,.07);transform:translateY(-1px);}
.tex-option-card .toc-icon{font-size:32.2px}
.tex-option-card .toc-label{font-family:var(--pixel);font-size:7.5px;color:var(--text);line-height:1.6}
.tex-option-card .toc-desc{font-size:11.5px;color:var(--dim);line-height:1.5}
#tex-option-cancel{width:100%;background:transparent;border:1px solid var(--border);color:var(--muted);border-radius:4px;padding:6px;cursor:pointer;font-family:var(--mono);font-size:12.6px;transition:all .15s}
#tex-option-cancel:hover{color:var(--text);border-color:var(--border2);background:var(--surface2)}

/* Template browser */
#tmpl-bg{position:fixed;inset:0;background:rgba(0,0,0,.75);display:flex;align-items:center;justify-content:center;z-index:10001;backdrop-filter:blur(4px)}
#tmpl-bg.off{display:none}
#tmpl-box{background:var(--surface);border:1px solid var(--border);border-radius:10px;width:680px;max-height:80vh;display:flex;flex-direction:column;box-shadow:0 24px 60px rgba(0,0,0,.6)}
#tmpl-header{padding:16px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:12px;flex-shrink:0}
#tmpl-header h3{font-family:var(--pixel);font-size:9.2px;color:var(--text);flex:1}
#tmpl-search{padding:6px 10px;background:var(--bg);border:1px solid var(--border);border-radius:4px;color:var(--text);font-family:var(--mono);font-size:12.6px;outline:none;width:200px}
#tmpl-search:focus{border-color:var(--blue)}
#tmpl-close-btn{background:none;border:1px solid var(--border);border-radius:4px;color:var(--muted);font-size:16.1px;padding:3px 8px;cursor:pointer;transition:all .15s}
#tmpl-close-btn:hover{color:var(--text);border-color:var(--border2)}
#tmpl-tabs{display:flex;border-bottom:1px solid var(--border);flex-shrink:0;padding:0 6px}
.tmpl-tab{padding:8px 14px;font-family:var(--pixel);font-size:6.9px;color:var(--dim);background:none;border:none;cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-1px;transition:all .15s}
.tmpl-tab.on{color:var(--green);border-bottom-color:var(--green)}
.tmpl-tab:hover:not(.on){color:var(--muted)}
#tmpl-grid-wrap{flex:1;overflow-y:auto;padding:14px}
#tmpl-grid-wrap::-webkit-scrollbar{width:6px}
#tmpl-grid-wrap::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}
#tmpl-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(72px,1fr));gap:8px}
.tmpl-cell{
display:flex;flex-direction:column;align-items:center;gap:5px;
padding:8px 4px;border:1px solid var(--border);border-radius:6px;
cursor:pointer;transition:all .12s;background:var(--surface2);
}
.tmpl-cell:hover{border-color:var(--green);background:rgba(63,185,80,.07);transform:translateY(-1px)}
.tmpl-cell.selected{border-color:var(--green);background:rgba(63,185,80,.12);}
.tmpl-thumb{width:48px;height:48px;image-rendering:pixelated;border-radius:3px;background:repeating-conic-gradient(#2a2a2a 0% 25%,#1a1a1a 0% 50%) 0 0/12px 12px}
.tmpl-name{font-size:9.2px;color:var(--muted);text-align:center;word-break:break-all;line-height:1.3;max-width:68px;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical}
.tmpl-cell:hover .tmpl-name{color:var(--text)}
#tmpl-footer{padding:12px 18px;border-top:1px solid var(--border);display:flex;align-items:center;gap:10px;flex-shrink:0}
#tmpl-selected-name{flex:1;font-size:12.6px;color:var(--muted);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
#tmpl-loading{padding:40px;text-align:center;color:var(--dim);font-size:13.8px;display:flex;flex-direction:column;align-items:center;gap:10px}

/* ── EXPORT DROPDOWN ── */
#export-wrap{position:relative;display:flex;gap:0}
#btn-export{border-radius:4px 0 0 4px;border-right:1px solid rgba(255,255,255,.15)}
#btn-export-arrow{border-radius:0 4px 4px 0;padding:6px 9px;border-left:none}
#export-dropdown{
display:none;position:absolute;top:calc(100% + 5px);right:0;
background:var(--surface);border:1px solid var(--border);
border-radius:6px;overflow:hidden;z-index:500;
box-shadow:0 8px 24px rgba(0,0,0,.5);min-width:190px;
}
#export-dropdown.open{display:block}
.exp-item{
padding:10px 14px;font-family:var(--mono);font-size:12.6px;font-weight:600;
color:var(--muted);cursor:pointer;transition:all .12s;white-space:nowrap;
}
.exp-item:hover{background:var(--surface2);color:var(--text)}

/* ── ADJUSTMENTS PANEL ── */
#adj-overlay{position:fixed;inset:0;background:rgba(0,0,0,.78);display:flex;align-items:center;justify-content:center;z-index:8000;backdrop-filter:blur(4px)}
#adj-overlay.off{display:none}
#adj-panel{width:710px;max-width:96vw;height:550px;max-height:93vh;background:var(--surface);border:1px solid var(--border);border-radius:10px;display:flex;flex-direction:column;box-shadow:0 28px 90px rgba(0,0,0,.65);overflow:hidden}
#adj-hdr{height:44px;flex-shrink:0;background:var(--surface2);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 16px;gap:10px}
#adj-hdr-title{font-family:var(--pixel);font-size:9.2px;color:var(--text);flex:1}
#adj-x{background:none;border:1px solid var(--border);border-radius:4px;color:var(--muted);font-size:16.1px;padding:2px 8px;cursor:pointer;transition:all .12s;font-family:var(--mono)}
#adj-x:hover{color:var(--red);border-color:var(--red)}
#adj-body{flex:1;display:flex;overflow:hidden;min-height:0}
#adj-list{width:160px;flex-shrink:0;border-right:1px solid var(--border);overflow-y:auto;padding:5px 0}
#adj-list::-webkit-scrollbar{width:4px}
#adj-list::-webkit-scrollbar-thumb{background:var(--border)}
.adj-li{padding:8px 14px;font-size:11.5px;color:var(--muted);cursor:pointer;transition:all .1s;display:flex;align-items:center;gap:7px;border-left:2px solid transparent;white-space:nowrap}
.adj-li:hover{color:var(--text);background:rgba(255,255,255,.03)}
.adj-li.on{color:var(--green);border-left-color:var(--green);background:rgba(63,185,80,.07);font-weight:600}
.adj-li-icon{width:18px;text-align:center;font-size:14.9px;flex-shrink:0}
#adj-ctrl{flex:1;overflow-y:auto;padding:20px;display:flex;flex-direction:column;gap:14px}
#adj-ctrl::-webkit-scrollbar{width:5px}
#adj-ctrl::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}
.adj-sec{display:none;flex-direction:column;gap:13px}
.adj-sec.on{display:flex}
.adj-sec-title{font-family:var(--pixel);font-size:8px;color:var(--green);letter-spacing:1px;padding-bottom:9px;border-bottom:1px solid var(--border)}
.adj-row{display:flex;flex-direction:column;gap:4px}
.adj-lr{display:flex;justify-content:space-between;align-items:center;font-size:11.5px}
.adj-lr .lbl{color:var(--muted)}.adj-lr .val{color:var(--text);font-weight:600;min-width:44px;text-align:right}
.adj-sl{width:100%;accent-color:var(--green);cursor:pointer;height:4px;margin:2px 0}
.adj-hint{font-size:11.5px;color:var(--dim);line-height:1.65}
.adj-solo{display:flex;align-items:center;justify-content:center;gap:12px;padding:14px 18px;background:var(--surface2);border:1px solid var(--border);border-radius:6px;font-size:12.6px;color:var(--muted);width:100%}
.adj-solo span:first-child{font-size:27.6px}
.adj-ftr{height:50px;flex-shrink:0;background:var(--surface2);border-top:1px solid var(--border);display:flex;align-items:center;justify-content:flex-end;gap:8px;padding:0 16px}
/* curves */
#cch-row{display:flex;gap:5px;margin-bottom:6px}
.cch{flex:1;padding:5px 0;font-size:11.5px;background:var(--surface2);border:1px solid var(--border);border-radius:4px;color:var(--muted);cursor:pointer;transition:all .1s;font-family:var(--mono);text-align:center}
.cch.on{border-color:var(--green);color:var(--green);background:rgba(63,185,80,.1)}
#adj-curve-cv{display:block;border:1px solid var(--border);border-radius:6px;cursor:crosshair;width:100%;height:220px}
.curve-tip{font-size:10.3px;color:var(--dim);text-align:center;margin-top:3px}
/* b&w presets */
.bwp-row{display:flex;gap:5px;flex-wrap:wrap;margin-top:4px}
.bwp{padding:3px 9px;font-size:10.3px;border:1px solid var(--border);border-radius:10px;background:var(--surface2);color:var(--dim);cursor:pointer;transition:all .1s;font-family:var(--mono)}
.bwp:hover{border-color:var(--green);color:var(--green)}

/* ── EASY COLOR SWAP MODAL ── */
#colorswap-bg{position:fixed;inset:0;background:rgba(0,0,0,.7);display:flex;align-items:center;justify-content:center;z-index:9000;backdrop-filter:blur(4px)}
#colorswap-bg.off{display:none}
#colorswap-box{width:400px;max-width:95vw;background:var(--surface);border:1px solid var(--border);border-radius:10px;display:flex;flex-direction:column;box-shadow:0 24px 70px rgba(0,0,0,.6);overflow:hidden}
#colorswap-header{display:flex;align-items:center;justify-content:space-between;padding:13px 16px;background:var(--surface2);border-bottom:1px solid var(--border);flex-shrink:0}
#colorswap-title{font-family:var(--pixel);font-size:9.2px;color:var(--text)}
#colorswap-close{background:none;border:1px solid var(--border);border-radius:4px;color:var(--muted);font-size:14.9px;padding:2px 7px;cursor:pointer;transition:all .12s;font-family:var(--mono)}
#colorswap-close:hover{color:var(--red);border-color:var(--red)}
#colorswap-body{padding:20px;display:flex;flex-direction:column;gap:14px}
#colorswap-footer{padding:12px 16px;background:var(--surface2);border-top:1px solid var(--border);display:flex;gap:8px;justify-content:flex-end}
#colorswap-footer button{font-size:12.6px;padding:6px 14px}

.cs-color-block{background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:14px;display:flex;flex-direction:column;gap:10px}
.cs-block-label{font-size:12.6px;font-weight:600;color:var(--text)}
.cs-block-hint{font-size:11.5px;color:var(--dim);font-weight:400}
.cs-picker-row{display:flex;align-items:center;gap:8px}
.cs-swatch{width:34px;height:34px;border-radius:6px;border:2px solid var(--border);flex-shrink:0;background:#ff0000}
.cs-hex{width:90px;background:var(--bg);border:1px solid var(--border);border-radius:4px;color:var(--text);font-family:var(--mono);font-size:12.6px;padding:5px 8px;outline:none;text-transform:uppercase}
.cs-hex:focus{border-color:var(--blue)}
#cs-from-eyedrop{font-size:11.5px;padding:5px 10px;white-space:nowrap}
#cs-from-eyedrop.sampling{color:var(--gold);border-color:var(--gold);background:rgba(210,153,34,.12);animation:pulse 1s ease-in-out infinite}
.cs-eyedrop-hint{font-size:11.5px;color:var(--gold);display:none;animation:pulse 1s ease-in-out infinite}
.cs-eyedrop-hint.on{display:block}
.cs-arrow{text-align:center;font-size:23px;color:var(--dim);line-height:1}
.cs-tolerance-row{background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:14px}
.cs-preview-row{font-size:12.6px;color:var(--muted);text-align:center;padding:6px;background:var(--surface2);border:1px solid var(--border);border-radius:6px}
#cs-preview-count{color:var(--green);font-weight:600}

/* ── LAYERS PANEL ── */
#sec-layers{padding:0!important}
.layers-toolbar{display:flex;gap:5px;padding:10px 12px 8px;border-bottom:1px solid var(--border)}
.layers-toolbar button{flex:1;font-size:10.3px;padding:4px 6px}
#layer-list{max-height:220px;overflow-y:auto;display:flex;flex-direction:column}
#layer-list::-webkit-scrollbar{width:4px}
#layer-list::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}
.layer-row{
display:flex;align-items:center;gap:6px;padding:5px 10px;
border-bottom:1px solid var(--border);cursor:pointer;
transition:background .1s;user-select:none;position:relative;
}
.layer-row:hover{background:rgba(255,255,255,.03)}
.layer-row.active{background:rgba(63,185,80,.08);border-left:2px solid var(--green)}
.layer-row:not(.active){border-left:2px solid transparent}
.layer-vis{
font-size:13.8px;flex-shrink:0;cursor:pointer;width:18px;text-align:center;
transition:opacity .1s;
}
.layer-vis.hidden{opacity:.25}
.layer-thumb{
width:24px;height:24px;flex-shrink:0;border-radius:2px;
image-rendering:pixelated;border:1px solid var(--border);
background:repeating-conic-gradient(#2a2a2a 0% 25%,#1a1a1a 0% 50%) 0 0/8px 8px;
}
.layer-name{flex:1;font-size:11.5px;color:var(--muted);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;cursor:text}
.layer-row.active .layer-name{color:var(--text)}
.layer-acts{display:flex;gap:2px;flex-shrink:0}
.layer-act-btn{
background:transparent;border:none;color:var(--dim);font-size:11.5px;
cursor:pointer;padding:2px 4px;border-radius:3px;transition:all .1s;line-height:1;
}
.layer-act-btn:hover{color:var(--text);background:var(--surface2)}
.layer-act-btn.del:hover{color:var(--red)}
.layer-props{padding:10px 12px;display:flex;flex-direction:column;gap:8px;border-top:1px solid var(--border)}
.layer-prop-row{display:flex;align-items:center;gap:7px;font-size:11.5px;color:var(--muted)}
.layer-prop-row label{width:50px;flex-shrink:0}
.layer-prop-row input[type=range]{flex:1;accent-color:var(--green);height:3px}
.layer-prop-row .lpv{min-width:28px;text-align:right;color:var(--text);font-size:11.5px}
.layer-blend-sel{
flex:1;background:var(--bg);border:1px solid var(--border);border-radius:4px;
color:var(--text);font-family:var(--mono);font-size:11.5px;padding:3px 6px;outline:none;cursor:pointer;
}
.layer-blend-sel:focus{border-color:var(--blue)}
.layer-bottom-row{display:flex;gap:5px;padding:8px 12px;border-top:1px solid var(--border)}
.layer-bottom-row button{flex:1;font-size:10.3px;padding:4px 5px}

/* ── MISC MENU ITEMS ── */
.misc-item{
display:flex;align-items:center;gap:12px;padding:12px 10px;
border:1px solid var(--border);border-radius:8px;cursor:pointer;
background:var(--surface2);transition:all .15s;
}
.misc-item:hover{border-color:var(--green);background:rgba(63,185,80,.07);transform:translateX(3px)}
.misc-item-icon{font-size:25.3px;flex-shrink:0}
.misc-item-text{flex:1;min-width:0}
.misc-item-title{font-size:16.4px;font-weight:600;color:var(--text);margin-bottom:3px}
.misc-item-desc{font-size:11.5px;color:var(--dim);line-height:1.5}
.misc-item-arrow{font-size:20.7px;color:var(--dim);flex-shrink:0;transition:color .15s}
.misc-item:hover .misc-item-arrow{color:var(--green)}

/* ── SKYBOX CONVERTER ── */
#skybox-converter{
position:fixed;inset:0;z-index:7000;
background:var(--bg);display:flex;flex-direction:column;overflow:hidden;
}
#skybox-converter.off{display:none}
#skybox-topbar{
height:48px;flex-shrink:0;background:var(--surface);border-bottom:2px solid var(--border);
display:flex;align-items:center;gap:14px;padding:0 16px;
}
#skybox-back{
background:transparent;border:1px solid var(--border);border-radius:4px;
color:var(--muted);font-family:var(--mono);font-size:12.6px;padding:5px 12px;
cursor:pointer;transition:all .15s;
}
#skybox-back:hover{color:var(--text);border-color:var(--border2);background:var(--surface2)}
#skybox-topbar-title{font-family:var(--pixel);font-size:12px;color:var(--green)}

.sbc-step{flex:1;overflow-y:auto;display:flex;flex-direction:column;align-items:center;padding:36px 24px 60px;gap:18px}
.sbc-step.off{display:none}
.sbc-step::-webkit-scrollbar{width:6px}
.sbc-step::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}

.sbc-hero-icon{font-size:59.8px;line-height:1}
.sbc-hero-title{font-family:var(--pixel);font-size:12.6px;color:var(--green);text-align:center;text-shadow:0 0 20px rgba(63,185,80,.35)}
.sbc-hero-sub{font-size:13.8px;color:var(--muted);text-align:center;max-width:560px;line-height:1.8}

.sbc-info-box{
background:var(--surface);border:1px solid var(--border);border-radius:10px;
padding:16px 20px;width:100%;max-width:560px;font-size:12.6px;color:var(--muted);line-height:1.8;
}
.sbc-info-box strong{color:var(--text)}
.sbc-info-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-top:8px}
.sbc-info-face{
background:var(--surface2);border:1px solid var(--border);border-radius:6px;
padding:8px;text-align:center;font-size:10.3px;color:var(--dim);font-family:var(--mono);
}
.sbc-info-face strong{display:block;font-size:12.6px;color:var(--text);margin-bottom:3px}

.sbc-drop-zone{
width:100%;max-width:500px;border:2px dashed var(--border);border-radius:12px;
padding:44px 32px;text-align:center;cursor:pointer;transition:all .2s;
background:var(--surface);display:flex;flex-direction:column;align-items:center;gap:10px;
}
.sbc-drop-zone:hover,.sbc-drop-zone.over{border-color:var(--green);box-shadow:0 0 30px rgba(63,185,80,.15);background:rgba(63,185,80,.04)}
.sbc-drop-icon{font-size:46px;animation:bob 3s ease-in-out infinite}
.sbc-drop-zone p{font-size:13.8px;color:var(--muted);line-height:1.7;margin:0}
.sbc-drop-note{font-size:11.5px;color:var(--dim);background:var(--surface2);border:1px solid var(--border);border-radius:6px;padding:3px 10px}

/* size selector */
.sbc-size-row{display:flex;align-items:center;gap:10px;font-size:12.6px;color:var(--muted)}
.sbc-size-btn{
padding:5px 14px;border:1px solid var(--border);border-radius:6px;
background:var(--surface2);color:var(--dim);cursor:pointer;font-family:var(--mono);font-size:11.5px;
transition:all .1s;
}
.sbc-size-btn:hover{border-color:var(--border2);color:var(--text)}
.sbc-size-btn.on{border-color:var(--green);color:var(--green);background:rgba(63,185,80,.1)}

/* processing */
.sbc-prog-bar{width:100%;max-width:440px;height:6px;background:var(--surface2);border-radius:3px;overflow:hidden;border:1px solid var(--border)}
#sbc-prog-fill{height:100%;width:0%;background:var(--green);border-radius:3px;transition:width .2s}
.sbc-log{width:100%;max-width:440px;background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:14px;font-size:11.5px;color:var(--muted);font-family:var(--mono);line-height:2;max-height:180px;overflow-y:auto}
.sbc-log::-webkit-scrollbar{width:4px}
.sbc-log::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}
.sbc-log-ok{color:var(--green)}
.sbc-log-info{color:var(--blue)}

/* result */
.sbc-face-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;width:100%;max-width:520px}
.sbc-face-card{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:10px;text-align:center;display:flex;flex-direction:column;gap:6px}
.sbc-face-card canvas{width:100%;border-radius:4px;image-rendering:pixelated;border:1px solid var(--border)}
.sbc-face-label{font-size:10.3px;color:var(--muted);font-family:var(--mono)}
.sbc-result-actions{display:flex;gap:10px;flex-wrap:wrap;justify-content:center;margin-top:4px}
.sbc-result-actions button{padding:9px 20px;font-size:12.6px}

/* scanlines */
body::after{content:'';position:fixed;inset:0;pointer-events:none;z-index:99999;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,.025) 2px,rgba(0,0,0,.025) 4px)}

/* ── MOBILE RESPONSIVE ── */
#mob-sidebar-toggle{display:none;background:transparent;border:1px solid var(--border);border-radius:4px;color:var(--muted);font-size:18.4px;padding:4px 9px;cursor:pointer;line-height:1;flex-shrink:0}
#mob-sidebar-toggle:hover{color:var(--text);border-color:var(--border2)}
#sidebar-backdrop{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:499;backdrop-filter:blur(2px)}

@media (max-width: 768px) {
  html,body{overflow:auto}

  /* Header */
  #header{padding:0 10px;gap:6px;height:46px;flex-wrap:nowrap;overflow:hidden}
  #logo{font-size:6.3px}
  #pack-tabs{max-width:130px}
  #mob-sidebar-toggle{display:block}
  #btn-misc{font-size:10.3px;padding:4px 8px}
  #btn-load{font-size:10.3px;padding:4px 8px}
  #btn-export{font-size:10.3px;padding:4px 8px}
  #btn-export-arrow{padding:4px 7px}

  /* Sidebar becomes a slide-in drawer */
  #sidebar{
    position:fixed;top:0;left:0;bottom:0;z-index:500;
    transform:translateX(-100%);transition:transform .25s cubic-bezier(.4,0,.2,1);
    width:280px;box-shadow:4px 0 24px rgba(0,0,0,.5);
  }
  #sidebar.mob-open{transform:translateX(0)}
  #sidebar-backdrop{display:block;opacity:0;pointer-events:none;transition:opacity .25s}
  #sidebar-backdrop.mob-open{opacity:1;pointer-events:auto}

  /* Right panel hidden on mobile */
  #rpanel{display:none}

  /* Body takes full width */
  #body{flex-direction:column}
  #editor{min-width:0;width:100%}

  /* Toolbar wraps and scrolls */
  #toolbar-img{height:auto;flex-wrap:wrap;gap:4px;padding:6px 8px;overflow-x:auto}
  #toolbar-img .tgrp{padding-right:6px;border-right:none;border-bottom:none}
  #toolbar-txt{height:auto;flex-wrap:wrap;gap:6px;padding:6px 10px}

  /* Canvas area */
  #canvas-area{min-height:50vh}

  /* Text editor */
  #text-editor{font-size:14.9px}

  /* Welcome screen */
  .ov-title{font-size:10.3px}
  .ov-sub{font-size:12.6px}
  .drop-box{padding:24px 20px}

  /* Modals full-width */
  #prompt-box{width:92vw}
  #modal{width:92vw}
  #colorswap-box{width:94vw}
  #adj-panel{width:98vw;height:92vh}
  #adj-list{width:130px}

  /* Skybox converter */
  .sbc-step{padding:24px 12px 40px}
  .sbc-info-grid{grid-template-columns:1fr 1fr}
  .sbc-face-grid{grid-template-columns:1fr 1fr}
  .sbc-result-actions{flex-direction:column;align-items:stretch}
  .sbc-result-actions button{width:100%}

  /* Misc / customizer panels full width */
  #misc-panel{width:88vw}
  #customizer{width:88vw}

  /* Layers panel */
  #sec-layers{display:none} /* hidden on mobile — too cramped */

  /* Export dropdown */
  #export-wrap{position:static}
  #export-dropdown{right:0;left:auto;min-width:170px}

  /* Skybox / misc converter pages */
  #skybox-topbar{padding:0 10px;gap:8px}
  #skybox-topbar-title{font-size:9px}
  #skybox-back{font-size:11.5px;padding:4px 9px}
  .sbc-hero-title{font-size:9.2px}
  .sbc-hero-sub{font-size:12.6px}
  .sbc-drop-zone{padding:28px 16px}

  /* Pack info modal */
  #sbc-info-modal{width:94vw}

  /* Adjustments modal list hidden, full ctrl */
  #adj-body{flex-direction:column}
  #adj-list{width:100%;height:44px;flex-direction:row;overflow-x:auto;overflow-y:hidden;border-right:none;border-bottom:1px solid var(--border);flex-shrink:0;padding:0}
  .adj-li{padding:8px 12px;border-left:none;border-bottom:2px solid transparent;white-space:nowrap}
  .adj-li.on{border-left:none;border-bottom-color:var(--green)}
  #adj-ctrl{padding:14px}
}

@media (max-width: 480px) {
  #logo{display:none}
  #pack-tabs{max-width:160px}
  #toolbar-img .tgrp{gap:3px}
  .ibtn{padding:4px 6px;font-size:13.8px}
  #adj-panel{height:98vh}
}

/* ── SKIN EDITOR ── */
#skin-editor{position:fixed;inset:0;z-index:7000;background:var(--bg);display:flex;flex-direction:column;overflow:hidden}
#skin-editor.off{display:none}
#skin-topbar{height:48px;flex-shrink:0;background:var(--surface);border-bottom:2px solid var(--border);display:flex;align-items:center;gap:12px;padding:0 16px}
#skin-back{background:transparent;border:1px solid var(--border);border-radius:4px;color:var(--muted);font-family:var(--mono);font-size:12.6px;padding:5px 12px;cursor:pointer;transition:all .15s}
#skin-back:hover{color:var(--text);border-color:var(--border2);background:var(--surface2)}
#skin-topbar-title{font-family:var(--pixel);font-size:12px;color:var(--green);flex:1}
#skin-topbar-actions{display:flex;gap:8px}
#skin-body{flex:1;display:flex;overflow:hidden;min-height:0}

/* Drop step */
#skin-step-drop{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:18px;padding:30px}
#skin-step-drop.off{display:none}
.skin-drop-zone{width:100%;max-width:440px;border:2px dashed var(--border);border-radius:12px;padding:44px 32px;text-align:center;cursor:pointer;transition:all .2s;background:var(--surface);display:flex;flex-direction:column;align-items:center;gap:10px}
.skin-drop-zone:hover,.skin-drop-zone.over{border-color:var(--green);box-shadow:0 0 28px rgba(63,185,80,.15);background:rgba(63,185,80,.04)}
.skin-drop-icon{font-size:55.2px;animation:bob 3s ease-in-out infinite}
.skin-drop-zone p{font-size:13.8px;color:var(--muted);line-height:1.7;margin:0}
.skin-drop-note{font-size:11.5px;color:var(--dim);background:var(--surface2);border:1px solid var(--border);border-radius:6px;padding:3px 10px}
.skin-hero-title{font-family:var(--pixel);font-size:16.4px;color:var(--green);text-shadow:0 0 18px rgba(63,185,80,.35)}
.skin-hero-sub{font-size:13.8px;color:var(--muted);text-align:center;max-width:480px;line-height:1.8}

/* Editor step */
#skin-step-edit{flex:1;display:flex;overflow:hidden;min-height:0}
#skin-step-edit.off{display:none}

/* 3D panel */
#skin-3d-panel{flex:1;display:flex;flex-direction:column;background:#0a0c10;position:relative;min-width:0}
#skin-3d-canvas{display:block;width:100%;height:100%}
#skin-3d-controls{
  position:absolute;top:10px;right:10px;display:flex;gap:6px;
}
#skin-bg-btn,#skin-3d-edit-btn{
  background:rgba(0,0,0,.55);border:1px solid var(--border);
  border-radius:4px;color:var(--muted);font-size:11.5px;padding:5px 10px;
  cursor:pointer;font-family:var(--mono);transition:all .15s;white-space:nowrap;
}
#skin-bg-btn:hover,#skin-3d-edit-btn:hover{color:var(--text);border-color:var(--border2)}
#skin-3d-edit-btn.active{
  background:rgba(63,185,80,.2);border-color:var(--green);
  color:var(--green);
}
#skin-grid-3d-btn.active{
  background:rgba(88,166,255,.15);border-color:var(--blue);
  color:var(--blue);
}
#skin-3d-canvas.paint-mode{cursor:crosshair}
#skin-3d-hint{position:absolute;bottom:10px;left:50%;transform:translateX(-50%);font-size:11.5px;color:rgba(255,255,255,.3);white-space:nowrap;pointer-events:none;font-family:var(--mono)}

/* 2D editor panel */
#skin-2d-panel{width:340px;flex-shrink:0;background:var(--surface);border-left:2px solid var(--border);display:flex;flex-direction:column;overflow:hidden;min-width:180px;max-width:70vw}
#skin-2d-resize-handle{width:5px;flex-shrink:0;background:transparent;cursor:col-resize;position:relative;z-index:10;transition:background .15s}
#skin-2d-resize-handle:hover,#skin-2d-resize-handle.dragging{background:var(--green)}
#skin-tools-bar{display:flex;align-items:center;gap:6px;padding:8px 10px;border-bottom:1px solid var(--border);flex-wrap:wrap}
#skin-canvas-wrap{flex:1;overflow:auto;display:flex;align-items:flex-start;justify-content:flex-start;background:repeating-conic-gradient(#1a1a1a 0% 25%,#111 0% 50%) 0 0/16px 16px;padding:12px}
#skin-canvas-wrap::-webkit-scrollbar{width:6px;height:6px}
#skin-canvas-wrap::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}
#skin-2d-canvas{image-rendering:pixelated;cursor:crosshair;border:1px solid var(--border)}
#skin-2d-statusbar{height:24px;flex-shrink:0;background:var(--surface2);border-top:1px solid var(--border);display:flex;align-items:center;gap:10px;padding:0 10px;font-size:11.5px;color:var(--dim)}
.skin-tool-btn{background:transparent;border:1px solid var(--border);border-radius:4px;color:var(--muted);font-size:14.9px;padding:4px 7px;cursor:pointer;transition:all .12s;line-height:1}
.skin-tool-btn:hover{color:var(--text);border-color:var(--border2);background:var(--surface2)}
.skin-tool-btn.on{color:var(--green);border-color:var(--green);background:rgba(63,185,80,.1)}
#skin-color-swatch{width:26px;height:26px;border-radius:4px;border:2px solid var(--border);cursor:pointer;flex-shrink:0}
#skin-zoom-lbl{font-size:11.5px;color:var(--muted);min-width:28px;text-align:center}

#skin-overlay-panel{
  position:absolute;bottom:36px;left:10px;
  background:rgba(10,12,16,.85);border:1px solid var(--border);
  border-radius:6px;padding:8px 10px;display:flex;flex-direction:row;gap:14px;
  backdrop-filter:blur(4px);
}
.skin-ov-col{display:flex;flex-direction:column;gap:4px}
.skin-ov-divider{width:1px;background:var(--border);align-self:stretch;margin:0 2px}
.skin-ov-title{font-family:var(--pixel);font-size:6.3px;color:var(--dim);letter-spacing:1px;text-transform:uppercase;margin-bottom:2px}
.skin-ov-row{display:flex;align-items:center;gap:6px;font-size:11.5px;color:var(--muted);cursor:pointer;transition:color .1s}
.skin-ov-row:hover{color:var(--text)}
.skin-ov-row input[type=checkbox]{accent-color:var(--green);width:12px;height:12px;cursor:pointer}

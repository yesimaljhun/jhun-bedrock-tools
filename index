function setAccent(hex) {
// darken by ~35% for -dim variant
const dimmed = darkenHex(hex, 0.35);
custState['--green']     = hex;
custState['--green-dim'] = dimmed;
document.getElementById('cust-accent-picker').value = hex;
document.getElementById('cust-accent-hex').value    = hex.toUpperCase();
applyCustState();
}

function darkenHex(hex, factor) {
const r = parseInt(hex.slice(1,3),16), g = parseInt(hex.slice(3,5),16), b = parseInt(hex.slice(5,7),16);
const dr = Math.round(r*(1-factor)), dg = Math.round(g*(1-factor)), db = Math.round(b*(1-factor));
return '#'+[dr,dg,db].map(v=>v.toString(16).padStart(2,'0')).join('');
}

/* wire up individual color pickers */
function wireColorPair(id, varName) {
const picker = document.getElementById(`cp-${id}`);
const hexInput = document.getElementById(`ch-${id}`);
const update = val => {
if (!/^#[0-9a-fA-F]{6}$/.test(val)) return;
custState[varName] = val;
picker.value    = val;
hexInput.value  = val.toUpperCase();
applyCustState();
syncCustControls();

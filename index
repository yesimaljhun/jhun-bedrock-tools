/* Apply the full current custState to :root */
function applyCustState() {
const root = document.documentElement;
const vars = ['--bg','--surface','--surface2','--border','--text','--muted','--green','--green-dim'];
vars.forEach(v => { if (custState[v]) root.style.setProperty(v, custState[v]); });

// font
loadFont(custState.font || DEFAULTS.font);
root.style.setProperty('--mono', `'${custState.font || DEFAULTS.font}', monospace`);
root.style.setProperty('--pixel', `'${custState.font || DEFAULTS.font}', monospace`);
document.body.style.fontFamily = `'${custState.font || DEFAULTS.font}', monospace`;

// logo size
document.getElementById('logo').style.fontSize = (custState.logoSize || DEFAULTS.logoSize) + 'px';

// logo text
const logoEl = document.getElementById('logo');
const t1 = custState.logoText ?? DEFAULTS.logoText;
const t2 = custState.logoSpan ?? DEFAULTS.logoSpan;
logoEl.innerHTML = `${t1}<span>${t2}</span>`;

// scanlines
document.body.classList.toggle('no-scanlines', !(custState.scanlines ?? true));

// glow
const glow = custState.glow ?? true;
document.getElementById('logo').style.textShadow = glow
? `0 0 16px color-mix(in srgb, ${custState['--green']||'#3fb950'} 40%, transparent)`
: 'none';

// background image
if (typeof applyBgImage === 'function') applyBgImage();
}

/* lazy-load a Google Font */
const loadedFonts = new Set(['JetBrains Mono','Press Start 2P']);
function loadFont(name) {
if (loadedFonts.has(name)) return;
const f = FONTS.find(x => x.id === name);
if (!f || !f.google) { loadedFonts.add(name); return; }
const link = document.createElement('link');
link.rel  = 'stylesheet';
link.href = `https://fonts.googleapis.com/css2?family=${f.google}&display=swap`;
document.head.appendChild(link);
loadedFonts.add(name);
}

